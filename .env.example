# Groq API Key - get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# SMTP Email Settings (for sending audit result emails to employees)
# For Gmail: use smtp.gmail.com, port 587, and an App Password (not your login password)
# Generate App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=Expense Auditor <your_email@gmail.com>
